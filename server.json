{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-09-29/server.schema.json",
  "name": "io.github.benediktgirz/storylenses",
  "version": "0.1.3",
  "description": "AI cover letter generation for agents. Job analysis, profile matching, narrative letters.",
  "repository": {
    "url": "https://github.com/benediktgirz/storylenses-mcp-server",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@storylenses/mcp-server",
      "version": "0.1.3",
      "transport": {
        "type": "stdio"
      }
    }
  ],
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://www.storylenses.app/api/mcp/endpoint",
      "headers": [
        {
          "name": "Authorization",
          "description": "StoryLenses API key (get one at storylenses.app/developers)",
          "value": "Bearer {STORYLENSES_API_KEY}",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ],
  "tools": [
    { "name": "storylenses_analyze_job" },
    { "name": "storylenses_match_profile" },
    { "name": "storylenses_generate_letter" },
    { "name": "storylenses_quality_check" },
    { "name": "storylenses_list_archetypes" }
  ]
}
